# Copy to .env and fill in.

TZ=Europe/London
BABY_NAME=Baby

# Backup sidecar
RCLONE_REMOTE=gdrive
RETAIN_LOCAL=7
RETAIN_REMOTE_DAYS=30

# Host port for the app (mapped to container :8000)
APP_PORT=8000

# Host interface the app port binds to.
# Default 127.0.0.1 = Tailscale-only (no LAN exposure). The Tailscale path
# in is set up automatically by ./setup.sh when Tailscale is detected.
# Set to 0.0.0.0 to expose on the LAN (e.g. if you don't use Tailscale).
APP_BIND=127.0.0.1
